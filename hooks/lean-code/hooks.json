{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$GLO_AGENT_HOOK_PATH/lean-code/scripts/smart-read.js\""
          }
        ],
        "description": "Intercept large file reads — warn and suggest targeted grep instead"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$GLO_AGENT_HOOK_PATH/lean-code/scripts/diff-capture.js\""
          }
        ],
        "description": "After file write, compute diff and log actual token savings vs full-rewrite"
      }
    ],
    "PromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$GLO_AGENT_HOOK_PATH/lean-code/scripts/token-tracker.js\""
          }
        ],
        "description": "Track cumulative token usage, warn when session grows large"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$GLO_AGENT_HOOK_PATH/lean-code/scripts/pre-compact.js\""
          }
        ],
        "description": "Save structured checkpoint before context compaction"
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$GLO_AGENT_HOOK_PATH/lean-code/scripts/post-compact.js\""
          }
        ],
        "description": "Re-inject critical checkpoint context after compaction"
      }
    ]
  }
}
